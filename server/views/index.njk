<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Timers</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/uikit@3.17.11/dist/css/uikit.min.css" />
  <script src="https://cdn.jsdelivr.net/npm/uikit@3.17.11/dist/js/uikit.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/uikit@3.17.11/dist/js/uikit-icons.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/vue@2.7.16/dist/vue.min.js"></script>
</head>
<body>
  <div id="app">
    <div v-if="!authenticated" class="uk-container uk-padding">
      <h1 class="uk-heading-small">Timers</h1>
      <div class="uk-margin">
        <input v-model="loginUser" class="uk-input uk-form-width-medium" placeholder="Имя пользователя" type="text" />
      </div>
      <div class="uk-margin">
        <input v-model="loginPass" class="uk-input uk-form-width-medium" placeholder="Пароль" type="password" />
      </div>
      <button type="button" class="uk-button uk-button-primary uk-margin-small-right" @click="doLogin">Войти</button>
      <button type="button" class="uk-button uk-button-default" @click="doSignup">Регистрация</button>
    </div>

    <div v-else class="uk-container uk-padding">
      <div class="uk-flex uk-flex-between uk-flex-middle uk-margin-bottom">
        <h1 class="uk-heading-small uk-margin-remove">Таймеры</h1>
        <button type="button" class="uk-button uk-button-default" @click="doLogout">Выйти</button>
      </div>

      <div class="uk-margin">
        <input v-model="desc" class="uk-input uk-form-width-large" placeholder="Описание нового таймера" type="text" @keyup.enter="createTimer" />
        <button type="button" class="uk-button uk-button-primary uk-margin-small-left" @click="createTimer">Старт</button>
      </div>

      <h3 class="uk-heading-bullet">Активные</h3>
      <table class="uk-table uk-table-divider uk-table-small">
        <thead>
          <tr>
            <th>ID</th>
            <th>Описание</th>
            <th>Прогресс</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="t in activeTimers" :key="t.id">
            <td><code>{{ t.id }}</code></td>
            <td>{{ t.description }}</td>
            <td>{{ formatDuration(t.progress) }}</td>
            <td><button type="button" class="uk-button uk-button-danger uk-button-small" @click="stopTimer(t.id)">Стоп</button></td>
          </tr>
        </tbody>
      </table>

      <h3 class="uk-heading-bullet">Завершённые</h3>
      <table class="uk-table uk-table-divider uk-table-small">
        <thead>
          <tr>
            <th>ID</th>
            <th>Описание</th>
            <th>Длительность</th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="t in oldTimers" :key="t.id">
            <td><code>{{ t.id }}</code></td>
            <td>{{ t.description }}</td>
            <td>{{ formatDuration(t.duration) }}</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  [% if user %]
  <script>
    window.USER_ID = "[[ user._id ]]";
    window.AUTH_TOKEN = "[[ userToken ]]";
  </script>
  [% else %]
  <script>
    window.USER_ID = "";
    window.AUTH_TOKEN = "";
  </script>
  [% endif %]
  <script src="/main.js"></script>
</body>
</html>
